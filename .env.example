# Server Configuration
PORT=5000

# Database Configuration
# Set to your MongoDB Atlas connection string or local MongoDB instance
MONGODB_URI=mongodb://localhost:27017/daily-planner

# Anthropic API Configuration
# Optional fallback API key for agent reasoning and natural language parsing,
# used automatically if NVIDIA NIM is not configured or a NIM call fails.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NVIDIA NIM Configuration (primary LLM provider for agent reasoning)
# Get a free API key at https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
# Chat/tool-calling model. Any NIM-hosted OpenAI-compatible chat model works.
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# Embedding model used for semantic memory search.
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# JWT Authentication
# Secret key used to sign JSON Web Tokens
JWT_SECRET=your_jwt_secret_key_here

# Telegram Bot (optional, free) — lets the agent push the morning briefing
# proactively instead of waiting for you to open the app, AND lets you reply
# to the bot to capture things on the go (same reasoning as the chat panel).
# 1. Message @BotFather on Telegram, send /newbot, follow the prompts.
# 2. Paste the token it gives you here.
# 3. In the app sidebar, message your new bot any text, then click "Detect My Chat ID".
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Shared secret Telegram echoes back on every webhook request (as the
# X-Telegram-Bot-Api-Secret-Token header) so /api/notifications/telegram/webhook
# can verify a request is really from Telegram and not a random POST from the
# internet. Any random string works — generate one and use the same value
# here and in Render's environment variables.
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret_here

# On Render this is auto-populated — no action needed. Only set this manually
# if hosting somewhere without an equivalent auto-provided public URL.
# TELEGRAM_WEBHOOK_URL=https://your-backend-domain.com

# Keeping the backend awake (recommended if hosted on Render's free tier)
# Render free-tier services sleep after ~15 min of no traffic. The background
# scheduler (hourly nudges, morning plan, Telegram digest, nightly reflection)
# lives inside this same process via setInterval, so it stops ticking entirely
# while asleep — no code fix can run if the process itself isn't running.
# Fix: use a free uptime monitor to ping GET /health every 5 minutes, keeping
# the instance continuously alive. No env var needed — just point it at:
#   https://<your-backend>.onrender.com/health
# e.g. UptimeRobot (free): New Monitor -> HTTP(s) -> paste the URL above ->
# interval 5 minutes.

# Server Configuration
PORT=5000

# Database Configuration
# Set to your MongoDB Atlas connection string or local MongoDB instance
MONGODB_URI=mongodb://localhost:27017/daily-planner

# Anthropic API Configuration
# Optional fallback API key for agent reasoning and natural language parsing,
# used automatically if NVIDIA NIM is not configured or a NIM call fails.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NVIDIA NIM Configuration (primary LLM provider for agent reasoning)
# Get a free API key at https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
# Chat/tool-calling model. Any NIM-hosted OpenAI-compatible chat model works.
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# Embedding model used for semantic memory search.
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# JWT Authentication
# Secret key used to sign JSON Web Tokens
JWT_SECRET=your_jwt_secret_key_here

# Telegram Bot (optional, free) — lets the agent push the morning briefing
# proactively instead of waiting for you to open the app.
# 1. Message @BotFather on Telegram, send /newbot, follow the prompts.
# 2. Paste the token it gives you here.
# 3. In the app sidebar, message your new bot any text, then click "Detect My Chat ID".
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

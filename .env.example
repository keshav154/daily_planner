# Server Configuration
PORT=5000

# Database Configuration
# Set to your MongoDB Atlas connection string or local MongoDB instance
MONGODB_URI=mongodb://localhost:27017/daily-planner

# Anthropic API Configuration
# Your Claude API key for agent reasoning and natural language parsing
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT Authentication
# Secret key used to sign JSON Web Tokens
JWT_SECRET=your_jwt_secret_key_here
